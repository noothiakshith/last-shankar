{
  "name": "nexis-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ml": "cd python-ml-service && source .venv/bin/activate && python3 main.py",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ml\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run --no-file-parallelism"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.15.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "prisma": "^7.5.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
